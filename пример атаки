def factorize(n: int) -> Tuple[int, int]:
    """
    Факторизация модуля n методом перебора делителей.
    Применима только для малых значений n (учебный пример).
    """
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return i, n // i
    raise ValueError(f"Не удалось факторизовать число {n}")


def rsa_attack(ciphertext: int, e: int, n: int) -> int:
    """
    Атака на RSA путём факторизации модуля.
    По известному открытому ключу (e, n) и шифртексту c
    восстанавливает исходное сообщение m.
    """
    p, q = factorize(n)
    phi = (p - 1) * (q - 1)
    d = mod_inverse(e, phi)
    m = mod_pow(ciphertext, d, n)
    return m


